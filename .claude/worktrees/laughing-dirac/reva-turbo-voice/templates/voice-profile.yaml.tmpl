# REVA-TURBO Voice Profile
# PM: {{PM_NAME}}
# Created: {{CREATED_DATE}}
# Last updated: {{UPDATED_DATE}}

pm:
  name: "{{PM_NAME}}"
  slug: "{{PM_SLUG}}"
  email: "{{PM_EMAIL}}"

voice:
  # Core tone (1=most formal, 10=most casual)
  tone: {{TONE}}
  formality: {{FORMALITY}}

  # Content style
  technical_depth: "{{TECHNICAL_DEPTH}}"      # minimal | moderate | deep
  sentence_length: "{{SENTENCE_LENGTH}}"      # short | medium | long
  detail_level: "{{DETAIL_LEVEL}}"            # concise | standard | thorough
  bullet_vs_prose: "{{BULLET_VS_PROSE}}"      # bullets | prose | mixed
  humor_level: "{{HUMOR_LEVEL}}"              # none | occasional | frequent
  urgency_language: "{{URGENCY_LANGUAGE}}"     # measured | direct | strong

email:
  greeting_style: "{{GREETING_STYLE}}"         # "Dear Mr./Ms." | "Hi [First]," | "Hey [First]," | "[First]," | custom
  greeting_custom: "{{GREETING_CUSTOM}}"       # Only if greeting_style is custom
  signoff_style: "{{SIGNOFF_STYLE}}"           # "Best regards," | "Thanks," | "Cheers," | "Best," | custom
  signoff_custom: "{{SIGNOFF_CUSTOM}}"         # Only if signoff_style is custom
  email_length: "{{EMAIL_LENGTH}}"             # short (3-5 sentences) | medium (1-2 paragraphs) | long (full detail)
  customer_tier_adaptation: {{CUSTOMER_TIER_ADAPTATION}}  # true | false — vary tone by customer relationship

reports:
  report_detail: "{{REPORT_DETAIL}}"           # executive_summary | standard | comprehensive
  quote_cover_style: "{{QUOTE_COVER_STYLE}}"   # formal_letter | brief_email | detailed_proposal

partners:
  partner_reference_style: "{{PARTNER_REFERENCE_STYLE}}"
  # Options:
  #   "our manufacturing partner"
  #   "the factory"
  #   "our team in [City]"
  #   "[Partner Name]"
  #   "our production facility"

phrases:
  favorites:
    # Phrases the PM uses naturally — engine will incorporate these
    # - "Happy to help with that"
    # - "Let me look into this"
    {{FAVORITE_PHRASES}}
  banned:
    # Phrases to NEVER use in generated content
    # - "synergy"
    # - "circle back"
    # - "leverage"
    {{BANNED_PHRASES}}

adaptation:
  internal_vs_external: {{INTERNAL_VS_EXTERNAL}}  # true | false — different voice for internal comms
  internal_override:
    tone: {{INTERNAL_TONE}}
    formality: {{INTERNAL_FORMALITY}}
    detail_level: "{{INTERNAL_DETAIL_LEVEL}}"

# Voice fingerprint summary (auto-generated from profile)
summary: "{{VOICE_SUMMARY}}"
# e.g., "Professional, concise, bullet-point oriented. Warm greetings, brief signoffs."
