# REVA-TURBO Workflow Configuration — Generated by reva-turbo-setup
# Last updated: {{SETUP_DATE}}

lifecycle:
  # 15 lifecycle stages — activate/deactivate as needed
  stages:
    - id: rfq-intake
      active: {{STAGE_RFQ_INTAKE}}
      display_name: "{{STAGE_RFQ_INTAKE_NAME}}"
      sla_days: {{STAGE_RFQ_INTAKE_SLA}}
      auto_advance: false

    - id: rfq-qualify
      active: {{STAGE_RFQ_QUALIFY}}
      display_name: "{{STAGE_RFQ_QUALIFY_NAME}}"
      sla_days: {{STAGE_RFQ_QUALIFY_SLA}}
      auto_advance: false

    - id: customer-gate
      active: {{STAGE_CUSTOMER_GATE}}
      display_name: "{{STAGE_CUSTOMER_GATE_NAME}}"
      sla_days: {{STAGE_CUSTOMER_GATE_SLA}}
      auto_advance: false
      conditional: true  # Only for new customers

    - id: rfq-quote
      active: {{STAGE_RFQ_QUOTE}}
      display_name: "{{STAGE_RFQ_QUOTE_NAME}}"
      sla_days: {{STAGE_RFQ_QUOTE_SLA}}
      auto_advance: false

    - id: customer-comms
      active: {{STAGE_CUSTOMER_COMMS}}
      display_name: "{{STAGE_CUSTOMER_COMMS_NAME}}"
      sla_days: {{STAGE_CUSTOMER_COMMS_SLA}}
      auto_advance: {{STAGE_CUSTOMER_COMMS_AUTO}}

    - id: export-compliance
      active: {{STAGE_EXPORT_COMPLIANCE}}
      display_name: "{{STAGE_EXPORT_COMPLIANCE_NAME}}"
      sla_days: {{STAGE_EXPORT_COMPLIANCE_SLA}}
      auto_advance: false        # HARD GATE — never auto-advance
      hard_gate: true

    - id: china-package
      active: {{STAGE_CHINA_PACKAGE}}
      display_name: "{{STAGE_CHINA_PACKAGE_NAME}}"
      sla_days: {{STAGE_CHINA_PACKAGE_SLA}}
      auto_advance: {{STAGE_CHINA_PACKAGE_AUTO}}

    - id: china-track
      active: {{STAGE_CHINA_TRACK}}
      display_name: "{{STAGE_CHINA_TRACK_NAME}}"
      sla_days: {{STAGE_CHINA_TRACK_SLA}}
      auto_advance: false

    - id: import-compliance
      active: {{STAGE_IMPORT_COMPLIANCE}}
      display_name: "{{STAGE_IMPORT_COMPLIANCE_NAME}}"
      sla_days: {{STAGE_IMPORT_COMPLIANCE_SLA}}
      auto_advance: false        # HARD GATE — conditional auto
      hard_gate: true

    - id: inspect
      active: {{STAGE_INSPECT}}
      display_name: "{{STAGE_INSPECT_NAME}}"
      sla_days: {{STAGE_INSPECT_SLA}}
      auto_advance: false

    - id: quality-gate
      active: {{STAGE_QUALITY_GATE}}
      display_name: "{{STAGE_QUALITY_GATE_NAME}}"
      sla_days: {{STAGE_QUALITY_GATE_SLA}}
      auto_advance: false

    - id: repackage
      active: {{STAGE_REPACKAGE}}
      display_name: "{{STAGE_REPACKAGE_NAME}}"
      sla_days: {{STAGE_REPACKAGE_SLA}}
      auto_advance: {{STAGE_REPACKAGE_AUTO}}

    - id: logistics
      active: {{STAGE_LOGISTICS}}
      display_name: "{{STAGE_LOGISTICS_NAME}}"
      sla_days: {{STAGE_LOGISTICS_SLA}}
      auto_advance: false

    - id: customer-comms-final
      active: {{STAGE_FINAL_COMMS}}
      display_name: "{{STAGE_FINAL_COMMS_NAME}}"
      sla_days: {{STAGE_FINAL_COMMS_SLA}}
      auto_advance: {{STAGE_FINAL_COMMS_AUTO}}

    - id: order-track
      active: {{STAGE_ORDER_TRACK}}
      display_name: "{{STAGE_ORDER_TRACK_NAME}}"
      sla_days: {{STAGE_ORDER_TRACK_SLA}}
      auto_advance: false

quality_gates:
  G1:
    name: "{{G1_NAME}}"                      # e.g., "Drawing Review"
    pass_threshold_pct: {{G1_THRESHOLD}}     # e.g., 100
    required: {{G1_REQUIRED}}
  G2:
    name: "{{G2_NAME}}"                      # e.g., "First Article Inspection"
    pass_threshold_pct: {{G2_THRESHOLD}}     # e.g., 95
    required: {{G2_REQUIRED}}
  G3:
    name: "{{G3_NAME}}"                      # e.g., "Production Sample"
    pass_threshold_pct: {{G3_THRESHOLD}}     # e.g., 98
    required: {{G3_REQUIRED}}
  G4:
    name: "{{G4_NAME}}"                      # e.g., "Final Inspection"
    pass_threshold_pct: {{G4_THRESHOLD}}     # e.g., 99
    required: {{G4_REQUIRED}}

priorities:
  - level: 1
    name: "Critical"
    description: "{{PRIORITY_1_DESC}}"
    sla_multiplier: 0.5                      # Half the normal SLA
    color: "red"
  - level: 2
    name: "High"
    description: "{{PRIORITY_2_DESC}}"
    sla_multiplier: 0.75
    color: "orange"
  - level: 3
    name: "Normal"
    description: "{{PRIORITY_3_DESC}}"
    sla_multiplier: 1.0
    color: "blue"
  - level: 4
    name: "Low"
    description: "{{PRIORITY_4_DESC}}"
    sla_multiplier: 1.5
    color: "gray"

autopilot:
  default_mode: "{{AUTOPILOT_MODE}}"         # manual | semi_auto | full_auto
  # See reva-turbo-autopilot for detailed mode configuration
