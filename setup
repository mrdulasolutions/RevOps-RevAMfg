#!/usr/bin/env bash
# setup — thin wrapper around install.sh for backward compatibility.
#
# The original setup script shipped with illegal bash variable names
# (REVA-TURBO_DIR — hyphens aren't legal in shell identifiers) and
# silently failed on fresh machines. Rather than maintain two code
# paths, this now delegates to install.sh, which is the one true
# installer. See install.sh for behavior and env var overrides.
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
echo "(setup is deprecated — running install.sh with REVA_TURBO_SKIP_GIT=1)"
exec env REVA_TURBO_DIR="$DIR" REVA_TURBO_SKIP_GIT=1 bash "$DIR/install.sh" "$@"
