# REVA-TURBO Document & Report Configuration — Generated by reva-turbo-setup
# Last updated: {{SETUP_DATE}}

branding:
  logo_path: "{{LOGO_PATH}}"
  company_name: "{{COMPANY_NAME}}"
  header_text: "{{HEADER_TEXT}}"
  footer_text: "{{FOOTER_TEXT}}"
  primary_color: "{{PRIMARY_COLOR}}"        # Hex color for report accents

output:
  default_format: "{{DEFAULT_FORMAT}}"       # docx | pdf | both
  naming_convention: "REVA-TURBO-{Type}-{YYYY-MM-DD}-{ShortName}"
  # Available tokens: {Type}, {YYYY-MM-DD}, {ShortName}, {Customer}, {RFQ_ID}, {PO_ID}, {PM}

storage:
  local_path: "{{LOCAL_OUTPUT_PATH}}"        # e.g., ~/Documents/REVA-TURBO-Reports
  organize_by: "{{ORGANIZE_BY}}"             # customer | date | type
  # Subfolders created automatically: Quotes/, Inspections/, Shipping/, NCRs/, etc.

cloud:
  enabled: {{CLOUD_ENABLED}}                 # true | false
  provider: "{{CLOUD_PROVIDER}}"             # google_drive | onedrive | dropbox | s3 | none
  sync_path: "{{CLOUD_SYNC_PATH}}"           # Cloud folder path
  auto_upload: {{AUTO_UPLOAD}}               # true | false — auto-upload on generation

backup:
  enabled: {{BACKUP_ENABLED}}                # true | false
  frequency: "{{BACKUP_FREQUENCY}}"          # daily | weekly | monthly
  destination: "{{BACKUP_DESTINATION}}"      # local_path or cloud_path
  retain_days: {{BACKUP_RETAIN_DAYS}}        # Days to keep backups
  include_state: true                        # Include ~/.reva-turbo/state/ in backups
  include_config: true                       # Include ~/.reva-turbo/*.yaml in backups

templates:
  custom_override_dir: "{{TEMPLATE_OVERRIDE_DIR}}"  # Path to custom templates (optional)
  # Place custom .md templates here to override defaults
  # Engine checks this dir first, falls back to built-in templates
