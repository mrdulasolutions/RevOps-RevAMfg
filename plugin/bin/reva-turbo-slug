#!/usr/bin/env bash
# reva-turbo-slug — generate a report slug from input text
#
# Usage:
#   reva-turbo-slug "Acme Corp Full-Face Respirators"
#   → acme-corp-full-face-respirators
#
#   echo "Some Long Name" | reva-turbo-slug
#   → some-long-name
set -euo pipefail

INPUT="${1:-$(cat)}"

printf '%s' "$INPUT" \
  | tr '[:upper:]' '[:lower:]' \
  | tr -cs '[:alnum:]' '-' \
  | sed 's/^-//;s/-$//' \
  | head -c 60
echo
