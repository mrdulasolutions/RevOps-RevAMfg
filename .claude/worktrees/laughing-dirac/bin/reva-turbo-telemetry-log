#!/usr/bin/env bash
# reva-turbo-telemetry-log — append a telemetry + dev log event to local JSONL
#
# Usage:
#   reva-turbo-telemetry-log --skill rfq-intake --duration 142 --outcome success \
#     --session-id "12345-1710756600" --pm "ray-yeh" \
#     --routed-to "reva-turbo-rfq-intake" \
#     --user-intent "new RFQ from Acme for PN-4820" \
#     --customer "Acme Corp" --order-id "PO-2026-0089" \
#     --note "customer flagged urgency"
#
# Env overrides:
#   REVA_TURBO_STATE_DIR  — override ~/.reva-turbo state directory
#   REVA_TURBO_DIR        — override auto-detected reva-turbo root
#
# Config (via reva-turbo-config):
#   telemetry: on   — log to ~/.reva-turbo/analytics/skill-usage.jsonl
#   telemetry: off  — do nothing (default)
set -uo pipefail

REVA_TURBO_DIR="${REVA_TURBO_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${REVA_TURBO_STATE_DIR:-$HOME/.reva-turbo}"
ANALYTICS_DIR="$STATE_DIR/analytics"
JSONL_FILE="$ANALYTICS_DIR/skill-usage.jsonl"
PENDING_DIR="$ANALYTICS_DIR"
CONFIG_CMD="$REVA_TURBO_DIR/bin/reva-turbo-config"
VERSION_FILE="$REVA_TURBO_DIR/VERSION"

# ─── Parse flags ─────────────────────────────────────────────
SKILL=""
DURATION=""
OUTCOME="unknown"
SESSION_ID=""
ERROR_CLASS=""
ERROR_MESSAGE=""
FAILED_STEP=""
EVENT_TYPE="skill_run"
SOURCE=""
PM=""
ROUTED_TO=""
USER_INTENT=""
CUSTOMER=""
ORDER_ID=""
NOTE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --skill)         SKILL="$2"; shift 2 ;;
    --duration)      DURATION="$2"; shift 2 ;;
    --outcome)       OUTCOME="$2"; shift 2 ;;
    --session-id)    SESSION_ID="$2"; shift 2 ;;
    --error-class)   ERROR_CLASS="$2"; shift 2 ;;
    --error-message) ERROR_MESSAGE="$2"; shift 2 ;;
    --failed-step)   FAILED_STEP="$2"; shift 2 ;;
    --event-type)    EVENT_TYPE="$2"; shift 2 ;;
    --source)        SOURCE="$2"; shift 2 ;;
    --pm)            PM="$2"; shift 2 ;;
    --routed-to)     ROUTED_TO="$2"; shift 2 ;;
    --user-intent)   USER_INTENT="$2"; shift 2 ;;
    --customer)      CUSTOMER="$2"; shift 2 ;;
    --order-id)      ORDER_ID="$2"; shift 2 ;;
    --note)          NOTE="$2"; shift 2 ;;
    *) shift ;;
  esac
done

SOURCE="${SOURCE:-live}"

# ─── Check telemetry setting ──────────────────────────────────
SETTING="$("$CONFIG_CMD" get telemetry 2>/dev/null || true)"
SETTING="${SETTING:-off}"

if [ "$SETTING" != "on" ]; then
  [ -n "$SESSION_ID" ] && rm -f "$PENDING_DIR/.pending-$SESSION_ID" 2>/dev/null || true
  exit 0
fi

# ─── Finalize stale .pending markers ────────────────────────
for PFILE in "$PENDING_DIR"/.pending-*; do
  [ -f "$PFILE" ] || continue
  PFILE_BASE="$(basename "$PFILE")"
  PFILE_SID="${PFILE_BASE#.pending-}"
  [ "$PFILE_SID" = "$SESSION_ID" ] && continue

  PENDING_DATA="$(cat "$PFILE" 2>/dev/null || true)"
  rm -f "$PFILE" 2>/dev/null || true
  if [ -n "$PENDING_DATA" ]; then
    P_SKILL="$(echo "$PENDING_DATA" | grep -o '"skill":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_TS="$(echo "$PENDING_DATA" | grep -o '"ts":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_SID="$(echo "$PENDING_DATA" | grep -o '"session_id":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_VER="$(echo "$PENDING_DATA" | grep -o '"reva_turbo_version":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
    P_ARCH="$(uname -m)"

    mkdir -p "$ANALYTICS_DIR"
    printf '{"v":2,"ts":"%s","event_type":"skill_run","skill":"%s","session_id":"%s","reva_turbo_version":"%s","os":"%s","arch":"%s","duration_s":null,"outcome":"unknown","sessions":1}\n' \
      "$P_TS" "$P_SKILL" "$P_SID" "$P_VER" "$P_OS" "$P_ARCH" >> "$JSONL_FILE" 2>/dev/null || true
  fi
done

[ -n "$SESSION_ID" ] && rm -f "$PENDING_DIR/.pending-$SESSION_ID" 2>/dev/null || true

# ─── Collect metadata ────────────────────────────────────────
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%S 2>/dev/null || echo "")"
REVA_TURBO_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"
SESSIONS="1"
if [ -d "$STATE_DIR/sessions" ]; then
  _SC="$(find "$STATE_DIR/sessions" -mmin -120 -type f 2>/dev/null | wc -l | tr -d ' \n\r\t')"
  [ -n "$_SC" ] && [ "$_SC" -gt 0 ] 2>/dev/null && SESSIONS="$_SC"
fi

# ─── Construct and append JSON ───────────────────────────────
mkdir -p "$ANALYTICS_DIR"

json_safe() { printf '%s' "$1" | tr -d '"\\\n\r\t' | head -c 400; }
long_safe() { printf '%s' "$1" | head -c 500 | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/	/\\t/g' | tr '\n\r' '  '; }

SKILL="$(json_safe "$SKILL")"
OUTCOME="$(json_safe "$OUTCOME")"
SESSION_ID="$(json_safe "$SESSION_ID")"
SOURCE="$(json_safe "$SOURCE")"
EVENT_TYPE="$(json_safe "$EVENT_TYPE")"
PM="$(json_safe "$PM")"
ROUTED_TO="$(json_safe "$ROUTED_TO")"
CUSTOMER="$(json_safe "$CUSTOMER")"
ORDER_ID="$(json_safe "$ORDER_ID")"

ERR_FIELD="null"
[ -n "$ERROR_CLASS" ] && ERR_FIELD="\"$(json_safe "$ERROR_CLASS")\""

ERR_MSG_FIELD="null"
[ -n "$ERROR_MESSAGE" ] && ERR_MSG_FIELD="\"$(long_safe "$ERROR_MESSAGE")\""

STEP_FIELD="null"
[ -n "$FAILED_STEP" ] && STEP_FIELD="\"$(json_safe "$FAILED_STEP")\""

INTENT_FIELD="null"
[ -n "$USER_INTENT" ] && INTENT_FIELD="\"$(long_safe "$USER_INTENT")\""

NOTE_FIELD="null"
[ -n "$NOTE" ] && NOTE_FIELD="\"$(long_safe "$NOTE")\""

ROUTED_FIELD="null"
[ -n "$ROUTED_TO" ] && ROUTED_FIELD="\"$ROUTED_TO\""

CUSTOMER_FIELD="null"
[ -n "$CUSTOMER" ] && CUSTOMER_FIELD="\"$CUSTOMER\""

ORDER_FIELD="null"
[ -n "$ORDER_ID" ] && ORDER_FIELD="\"$ORDER_ID\""

if [ -n "$DURATION" ] && [ "$DURATION" -gt 86400 ] 2>/dev/null; then DURATION=""; fi
if [ -n "$DURATION" ] && [ "$DURATION" -lt 0 ] 2>/dev/null; then DURATION=""; fi

DUR_FIELD="null"
[ -n "$DURATION" ] && DUR_FIELD="$DURATION"

PM_FIELD="null"
[ -n "$PM" ] && PM_FIELD="\"$PM\""

printf '{"v":2,"ts":"%s","event_type":"%s","skill":"%s","routed_to":%s,"session_id":"%s","reva_turbo_version":"%s","os":"%s","arch":"%s","duration_s":%s,"outcome":"%s","pm":%s,"customer":%s,"order_id":%s,"user_intent":%s,"note":%s,"error_class":%s,"error_message":%s,"failed_step":%s,"sessions":%s,"source":"%s"}\n' \
  "$TS" "$EVENT_TYPE" "$SKILL" "$ROUTED_FIELD" "$SESSION_ID" "$REVA_TURBO_VERSION" "$OS" "$ARCH" \
  "$DUR_FIELD" "$OUTCOME" "$PM_FIELD" "$CUSTOMER_FIELD" "$ORDER_FIELD" \
  "$INTENT_FIELD" "$NOTE_FIELD" \
  "$ERR_FIELD" "$ERR_MSG_FIELD" "$STEP_FIELD" \
  "${SESSIONS:-1}" "$SOURCE" >> "$JSONL_FILE" 2>/dev/null || true

exit 0
