#!/usr/bin/env bash
# reva-turbo-session-track — PID-based session lifecycle management
#
# Usage:
#   reva-turbo-session-track start   — register this session
#   reva-turbo-session-track count   — count active sessions (last 2h)
#   reva-turbo-session-track cleanup — remove stale session files
set -euo pipefail

STATE_DIR="${REVA-TURBO_STATE_DIR:-$HOME/.reva-turbo}"
SESSIONS_DIR="$STATE_DIR/sessions"

case "${1:-}" in
  start)
    mkdir -p "$SESSIONS_DIR"
    touch "$SESSIONS_DIR/$PPID"
    echo "$PPID"
    ;;
  count)
    if [ -d "$SESSIONS_DIR" ]; then
      find "$SESSIONS_DIR" -mmin -120 -type f 2>/dev/null | wc -l | tr -d ' '
    else
      echo "0"
    fi
    ;;
  cleanup)
    if [ -d "$SESSIONS_DIR" ]; then
      find "$SESSIONS_DIR" -mmin +120 -type f -delete 2>/dev/null || true
      echo "Stale sessions cleaned"
    fi
    ;;
  *)
    echo "Usage: reva-turbo-session-track {start|count|cleanup}"
    exit 1
    ;;
esac
