#!/usr/bin/env bash
# pmlord-config — read/write ~/.pmlord/config.yaml
#
# Usage:
#   pmlord-config get <key>          — read a config value
#   pmlord-config set <key> <value>  — write a config value
#   pmlord-config list               — show all config
#
# Env overrides (for testing):
#   PMLORD_STATE_DIR  — override ~/.pmlord state directory
set -euo pipefail

STATE_DIR="${PMLORD_STATE_DIR:-$HOME/.pmlord}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: pmlord-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: pmlord-config set <key> <value>}"
    VALUE="${3:?Usage: pmlord-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: pmlord-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
