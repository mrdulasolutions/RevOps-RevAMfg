# PMLORD Shipping & Logistics Configuration — Generated by pmlord-setup
# Last updated: {{SETUP_DATE}}

carriers:
  preferred:
    domestic: "{{DOMESTIC_CARRIER}}"        # FedEx | UPS | USPS
    international_air: "{{AIR_CARRIER}}"    # FedEx | DHL | UPS
    international_ocean: "{{OCEAN_CARRIER}}" # Freight forwarder name
  accounts:
    # - carrier: "FedEx"
    #   account_number: "XXXX-XXXX"
    #   service_level: "Priority"
    {{CARRIER_ACCOUNTS}}

customs_broker:
  name: "{{BROKER_NAME}}"
  company: "{{BROKER_COMPANY}}"
  email: "{{BROKER_EMAIL}}"
  phone: "{{BROKER_PHONE}}"
  license_number: "{{BROKER_LICENSE}}"

freight_forwarder:
  name: "{{FORWARDER_NAME}}"
  company: "{{FORWARDER_COMPANY}}"
  email: "{{FORWARDER_EMAIL}}"
  phone: "{{FORWARDER_PHONE}}"

ports:
  origin:
    # China origin ports (common)
    # - code: "CNSHA"
    #   name: "Shanghai"
    {{ORIGIN_PORTS}}
  destination:
    # US destination ports (common)
    # - code: "USLAX"
    #   name: "Los Angeles / Long Beach"
    {{DESTINATION_PORTS}}

incoterms:
  default: "{{DEFAULT_INCOTERMS}}"         # FOB | CIF | DDP | EXW | FCA | DAP
  preferred_by_value:
    under_10k: "FOB"
    10k_to_50k: "CIF"
    over_50k: "DDP"

insurance:
  provider: "{{INSURANCE_PROVIDER}}"
  policy_number: "{{INSURANCE_POLICY}}"
  coverage_percentage: {{INSURANCE_COVERAGE_PCT}}  # e.g., 110 (110% of invoice value)
  auto_insure_above: {{AUTO_INSURE_THRESHOLD}}     # USD threshold

shipping_rules:
  # Value-based shipping method selection
  under_500: "international_air"
  500_to_5000: "international_air"
  5000_to_20000: "ocean_or_air"
  over_20000: "international_ocean"
  rush_surcharge_pct: 25
