# PMLORD Connector Configuration — Generated by pmlord-setup
# Last updated: {{SETUP_DATE}}

crm:
  type: "{{CRM_TYPE}}"                       # hubspot | dynamics | power_apps | salesforce | none
  api_url: "{{CRM_API_URL}}"
  api_key: "{{CRM_API_KEY}}"                 # Store securely — consider env var
  sync_enabled: {{CRM_SYNC_ENABLED}}
  sync_frequency: "{{CRM_SYNC_FREQUENCY}}"   # realtime | hourly | daily
  field_mapping:
    customer_name: "{{CRM_FIELD_CUSTOMER}}"
    contact_email: "{{CRM_FIELD_EMAIL}}"
    order_status: "{{CRM_FIELD_STATUS}}"
    rfq_id: "{{CRM_FIELD_RFQ}}"

email:
  provider: "{{EMAIL_PROVIDER}}"             # hostinger | gmail | outlook | none
  sending_address: "{{EMAIL_SENDING_ADDRESS}}"
  display_name: "{{EMAIL_DISPLAY_NAME}}"
  # Provider-specific settings:
  # Hostinger: SMTP/IMAP via hostinger-email MCP
  # Gmail: OAuth via gmail MCP
  # Outlook: Microsoft Graph API
  smtp:
    host: "{{SMTP_HOST}}"
    port: {{SMTP_PORT}}
    username: "{{SMTP_USERNAME}}"
    # Password: use environment variable PMLORD_SMTP_PASSWORD
    tls: true
  signature: |
    {{EMAIL_SIGNATURE}}

erp:
  type: "{{ERP_TYPE}}"                       # sap | netsuite | quickbooks | none
  connection_url: "{{ERP_CONNECTION_URL}}"
  sync_inventory: {{ERP_SYNC_INVENTORY}}
  sync_frequency: "{{ERP_SYNC_FREQUENCY}}"   # hourly | daily | manual

slack:
  enabled: {{SLACK_ENABLED}}                 # true | false
  workspace_url: "{{SLACK_WORKSPACE_URL}}"
  # Bot token: use environment variable PMLORD_SLACK_TOKEN
  channels:
    alerts: "{{SLACK_CHANNEL_ALERTS}}"       # e.g., #pmlord-alerts
    orders: "{{SLACK_CHANNEL_ORDERS}}"       # e.g., #orders
    escalation: "{{SLACK_CHANNEL_ESCALATION}}" # e.g., #escalations

imessage:
  enabled: {{IMESSAGE_ENABLED}}              # true | false (macOS only)
  contacts:
    # PM contacts for pulse alerts via iMessage
    # - name: "PM Name"
    #   phone: "+1-555-000-0000"
    {{IMESSAGE_CONTACTS}}

webhooks:
  # External webhook URLs for integrations
  # - name: "Zapier"
  #   url: "https://hooks.zapier.com/..."
  #   events: ["order_created", "quality_fail", "shipment"]
  {{WEBHOOK_URLS}}
